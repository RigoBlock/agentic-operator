{
  "name": "agentic-operator",
  "version": "0.4.0",
  "description": "Agentic trading operator for Rigoblock vaults — Cloudflare Worker + EIP-7702 delegation",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-wdk-for-worker.cjs && npm run build:wdk-browser && npm run build:wdk-secret-manager",
    "build:wdk-browser": "esbuild --bundle --platform=browser --format=esm --outfile=public/wdk-evm.js --inject:scripts/wdk-buffer-shim.js --external:node:crypto --minify node_modules/@tetherto/wdk-wallet-evm/index.js",
    "build:wdk-secret-manager": "esbuild --bundle --platform=browser --format=esm --outfile=public/wdk-secret-manager.js --inject:scripts/wdk-buffer-shim.js --alias:bare-crypto=scripts/bare-crypto-browser-shim.cjs --alias:sodium-universal=scripts/sodium-universal-browser-shim.cjs --external:node:crypto --minify node_modules/@tetherto/wdk-secret-manager/index.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:quote": "npx tsx scripts/test-uniswap-quote.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aa-sdk/core": "^4.84.1",
    "@account-kit/infra": "^4.84.1",
    "@account-kit/wallet-client": "^4.84.1",
    "@coinbase/x402": "^2.1.0",
    "@metamask/smart-accounts-kit": "^0.4.0-beta.1",
    "@tetherto/wdk-secret-manager": "^1.0.0-beta.3",
    "@tetherto/wdk-wallet-evm": "^2.0.0-rc.1",
    "@uniswap/sdk-core": "^7.12.2",
    "@uniswap/v4-sdk": "^1.29.1",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/extensions": "^2.6.0",
    "bip39": "^3.1.0",
    "hono": "^4.6.0",
    "openai": "^4.70.0",
    "sodium-javascript": "^0.8.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.1",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/node": "^22.0.0",
    "ethers": "^5.8.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.67.0"
  }
}
